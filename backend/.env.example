# Server
CLIENT_PORT=3000
ADMIN_PORT=3001
SITE_URL=https://petid.link

# JWT
CLIENT_JWT_SECRET=
ADMIN_JWT_SECRET=
# CLIENT_SESSION_MAX_AGE=2592000000        # 可选，客户端 session 有效期（毫秒），默认 30 天
# CLIENT_SESSION_RENEW_THRESHOLD=604800000 # 可选，客户端续期阈值（毫秒），默认 7 天
# ADMIN_SESSION_MAX_AGE=604800000          # 可选，管理端 session 有效期（毫秒），默认 7 天
# ADMIN_SESSION_RENEW_THRESHOLD=86400000   # 可选，管理端续期阈值（毫秒），默认 1 天

# WeChat - 小程序
WECHAT_MINIPROGRAM_APP_ID=
WECHAT_MINIPROGRAM_APP_SECRET=

# WeChat - 服务号
WECHAT_MP_APP_ID=
WECHAT_MP_APP_SECRET=

# 短信服务（阿里云）
SMS_PROVIDER=aliyun
SMS_ACCESS_KEY_ID=
SMS_ACCESS_KEY_SECRET=
SMS_SIGN_NAME=PetID
SMS_TEMPLATE_CODE=

# 邮件服务（SMTP）
MAIL_HOST=
MAIL_PORT=465
MAIL_USER=
MAIL_PASS=
MAIL_FROM=noreply@petid.link

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# 验证码配置（可选）
# VERIFY_CODE_TTL=300000       # 验证码有效期（毫秒），默认 5 分钟
# VERIFY_CODE_INTERVAL=60000   # 发送间隔（毫秒），默认 60 秒
# VERIFY_CODE_LENGTH=6         # 验证码长度，默认 6 位

# 阿里云 OSS
OSS_REGION=oss-cn-hangzhou
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=
OSS_CDN_DOMAIN=               # 可选，CDN 加速域名
